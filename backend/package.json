{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "dev": "nodemon --exec ts-node src/index.ts",
        "build": "tsc",
        "postbuild": "rm -rf dist/generated && cp -r src/generated dist/generated",
        "typecheck": "tsc --noEmit",
        "start": "node dist/index.js",
        "studio": "prisma studio",
        "test": "NODE_ENV=test vitest run",
        "test:watch": "vitest",
        "lint": "eslint .",
        "format": "prettier --write src/",
        "prepare": "husky",
        "prisma:devMigrate": "prisma migrate dev",
        "prisma:migrate": "prisma migrate deploy",
        "prisma:generate": "prisma generate"
    },
    "lint-staged": {
        "*.ts": [
            "prettier --write",
            "eslint --fix"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@prisma/adapter-pg": "^7.4.1",
        "@prisma/client": "^7.4.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/jsonwebtoken": "^9.0.10",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.19.0",
        "resend": "^6.17.2",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.1",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.1",
        "nodemon": "^3.1.14",
        "openapi-fetch": "^0.17.0",
        "openapi-typescript": "^7.13.0",
        "prettier": "^3.8.1",
        "prisma": "^7.4.1",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.18"
    }
