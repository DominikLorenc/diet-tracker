# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/diet_tracker?schema=public"

# ── Auth ────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use a long, random string in real use.
# e.g. generate one with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret"

# ── CORS ────────────────────────────────────────────────
# Lista dozwolonych originów (frontend) oddzielona przecinkami.
# Na produkcji ustaw na domenę frontendu, np. https://diet-tracker.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
