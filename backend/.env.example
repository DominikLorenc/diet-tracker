# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/diet_tracker?schema=public"

# ── Auth ────────────────────────────────────────────────
# Secret used to sign JWT tokens. Use a long, random string in real use.
# e.g. generate one with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret"

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (frontend).
# In production set this to the frontend domain, e.g. https://diet-tracker.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend ────────────────────────────────────────────
# Base URL of the frontend — used to build links in emails (e.g. password reset).
# In production: the frontend domain, e.g. https://diet-tracker.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Email (Resend) ──────────────────────────────────────
# API key from https://resend.com → API Keys. Keep it secret, never commit it.
RESEND_API_KEY=re_your_api_key_here
