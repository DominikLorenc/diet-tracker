# Copy this file to .env.local and fill in the values.

# ── Backend API ─────────────────────────────────────────
# Base URL of the backend API (see backend/.env -> PORT)
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# Server-side target for the /api/v1 rewrite proxy (next.config.ts).
# Only used in production (Vercel); locally the rewrite is dormant and
# falls back to http://localhost:4000. Set this on Vercel.
BACKEND_URL="https://diet-tracker-fprp.onrender.com"

# ── Supabase (product image storage) ────────────────────
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
